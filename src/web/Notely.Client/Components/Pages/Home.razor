@page "/"

<PageTitle>Notely - Your Digital Notes</PageTitle>

<section class="home-shell">
    <div class="hero-card">
        <p class="eyebrow">Personal Workspace</p>
        <h1>Write less noise, keep more signal.</h1>
        <p class="subtitle">
            Notely helps you capture notes, group them by categories, and stay organized with tags.
            Fast, simple, and focused.
        </p>
        <div class="hero-actions">
            <a href="/notes" class="btn btn-primary">Open Notes</a>
            <a href="/notes/create" class="btn btn-outline-primary">Create Note</a>
        </div>
    </div>

    <div class="feature-grid">
        <article class="feature-card">
            <span class="feature-badge">01</span>
            <h3>Focused Note Flow</h3>
            <p>Create, edit, pin, and archive notes without extra clicks.</p>
        </article>
        <article class="feature-card">
            <span class="feature-badge">02</span>
            <h3>Smart Organization</h3>
            <p>Use categories and tags to keep your knowledge structured.</p>
        </article>
        <article class="feature-card">
            <span class="feature-badge">03</span>
            <h3>Quick Retrieval</h3>
            <p>Find what you need quickly and keep important notes visible.</p>
        </article>
    </div>

    <div class="quick-links">
        <a href="/categories">Manage Categories</a>
        <a href="/tags">Manage Tags</a>
    </div>
</section>
